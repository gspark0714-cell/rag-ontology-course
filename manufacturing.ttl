@prefix mfg: <http://manufacturing.org/ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.w3.org/2002/07/owl#> .

[ rdf:type owl:Ontology
 ] .

#################################################################
#    Object Properties
#################################################################

###  http://manufacturing.org/ontology#포함한다
mfg:포함한다 rdf:type owl:ObjectProperty .


#################################################################
#    Data properties
#################################################################

###  http://manufacturing.org/ontology#무게
mfg:무게 rdf:type owl:DatatypeProperty .


###  http://manufacturing.org/ontology#제조사
mfg:제조사 rdf:type owl:DatatypeProperty .


#################################################################
#    Classes
#################################################################

###  http://example.invalid/ontologies/ont.owl#불량유형
<http://example.invalid/ontologies/ont.owl#불량유형> rdf:type owl:Class .


###  http://example.invalid/ontologies/ont.owl#설비유형
<http://example.invalid/ontologies/ont.owl#설비유형> rdf:type owl:Class .


###  http://example.invalid/ontologies/ont.owl#작업자직급
<http://example.invalid/ontologies/ont.owl#작업자직급> rdf:type owl:Class .


###  http://manufacturing.org/ontology#부품
mfg:부품 rdf:type owl:Class ;
       rdfs:subClassOf mfg:제품 .


###  http://manufacturing.org/ontology#제품
mfg:제품 rdf:type owl:Class .


#################################################################
#    Individuals
#################################################################

###  http://example.invalid/ontologies/ont.owl#고급
<http://example.invalid/ontologies/ont.owl#고급> rdf:type owl:NamedIndividual ,
                                                        <http://example.invalid/ontologies/ont.owl#작업자직급> .


###  http://example.invalid/ontologies/ont.owl#중급
<http://example.invalid/ontologies/ont.owl#중급> rdf:type owl:NamedIndividual ,
                                                        <http://example.invalid/ontologies/ont.owl#작업자직급> .


###  http://example.invalid/ontologies/ont.owl#초급
<http://example.invalid/ontologies/ont.owl#초급> rdf:type owl:NamedIndividual ,
                                                        <http://example.invalid/ontologies/ont.owl#작업자직급> .


###  http://manufacturing.org/ontology#모터
mfg:모터 rdf:type owl:NamedIndividual ,
                mfg:부품 ;
       mfg:포함한다 mfg:베어링 ,
                mfg:샤프트 ;
       mfg:무게 "5.0"^^xsd:float ;
       mfg:제조사 "현대전자" ;
       rdfs:label "모터"@ko .


###  http://manufacturing.org/ontology#베어링
mfg:베어링 rdf:type owl:NamedIndividual ,
                 mfg:부품 ;
        rdfs:label "베어링"@ko .


###  http://manufacturing.org/ontology#산업용펌프
mfg:산업용펌프 rdf:type owl:NamedIndividual ,
                   mfg:제품 ;
          mfg:포함한다 mfg:모터 ;
          mfg:무게 "50.0"^^xsd:float ;
          rdfs:label "산업용펌프"@ko .


###  http://manufacturing.org/ontology#샤프트
mfg:샤프트 rdf:type owl:NamedIndividual ,
                 mfg:부품 ;
        rdfs:label "샤프트"@ko .


