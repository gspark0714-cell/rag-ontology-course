<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://manufacturing.org/ontology"
         xmlns="http://manufacturing.org/ontology#">

<owl:Ontology rdf:about="http://manufacturing.org/ontology"/>

<owl:ObjectProperty rdf:about="#포함한다">
  <rdfs:domain rdf:resource="#제품"/>
  <rdfs:range rdf:resource="#부품"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#사용한다">
  <rdfs:domain rdf:resource="#공정"/>
  <rdfs:range rdf:resource="#설비"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#담당한다">
  <rdfs:domain rdf:resource="#공정"/>
  <rdfs:range rdf:resource="#작업자"/>
</owl:ObjectProperty>

<owl:DatatypeProperty rdf:about="#무게">
  <rdfs:domain rdf:resource="#부품"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#작업시간">
  <rdfs:domain rdf:resource="#공정"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#불량율">
  <rdfs:domain rdf:resource="#부품"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#점검필요">
  <rdfs:domain rdf:resource="#부품"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#우선순위">
  <rdfs:domain rdf:resource="#부품"/>
  <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
</owl:DatatypeProperty>

<owl:Class rdf:about="#제품">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#부품">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#공정">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#설비">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#작업자">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#대형부품">
  <rdfs:subClassOf rdf:resource="#부품"/>
</owl:Class>

<owl:Class rdf:about="#고위험부품">
  <rdfs:subClassOf rdf:resource="#부품"/>
</owl:Class>

<owl:Class rdf:about="#핵심부품">
  <rdfs:subClassOf rdf:resource="#부품"/>
</owl:Class>

<owl:Class rdf:about="#긴급점검공정">
  <rdfs:subClassOf rdf:resource="#공정"/>
</owl:Class>

<owl:NamedIndividual rdf:about="#산업용펌프">
  <rdf:type rdf:resource="#제품"/>
  <포함한다 rdf:resource="#모터"/>
  <포함한다 rdf:resource="#케이싱"/>
  <포함한다 rdf:resource="#임펠러"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#모터">
  <rdf:type rdf:resource="#부품"/>
  <포함한다 rdf:resource="#베어링"/>
  <포함한다 rdf:resource="#샤프트"/>
  <무게 rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">5.0</무게>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#케이싱">
  <rdf:type rdf:resource="#부품"/>
  <무게 rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">8.0</무게>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#임펠러">
  <rdf:type rdf:resource="#부품"/>
  <무게 rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">2.0</무게>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#압력펌프">
  <rdf:type rdf:resource="#제품"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#베어링">
  <rdf:type rdf:resource="#부품"/>
  <rdf:type rdf:resource="#고위험부품"/>
  <무게 rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0.5</무게>
  <불량율 rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0.05</불량율>
  <점검필요 rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</점검필요>
  <우선순위 rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</우선순위>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#샤프트">
  <rdf:type rdf:resource="#부품"/>
  <무게 rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">1.5</무게>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#조립공정1">
  <rdf:type rdf:resource="#공정"/>
  <사용한다 rdf:resource="#선반기계A"/>
  <작업시간 rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">30</작업시간>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#선반기계A">
  <rdf:type rdf:resource="#설비"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#가공공정1">
  <rdf:type rdf:resource="#공정"/>
  <사용한다 rdf:resource="#용접기B"/>
  <rdf:type rdf:resource="#긴급점검공정"/>
  <작업시간 rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">60</작업시간>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#용접기B">
  <rdf:type rdf:resource="#설비"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#검사공정1">
  <rdf:type rdf:resource="#공정"/>
  <사용한다 rdf:resource="#검사장비C"/>
  <작업시간 rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">15</작업시간>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#검사장비C">
  <rdf:type rdf:resource="#설비"/>
</owl:NamedIndividual>

<owl:AllDisjointClasses>
  <owl:members rdf:parseType="Collection">
    <rdf:Description rdf:about="#제품"/>
    <rdf:Description rdf:about="#공정"/>
    <rdf:Description rdf:about="#설비"/>
    <rdf:Description rdf:about="#작업자"/>
  </owl:members>
</owl:AllDisjointClasses>


</rdf:RDF>
